<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender: human-readable for local development -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        Rolling file appender: one log file per test run, rotated daily.
        Fix applied: using RollingFileAppender instead of FileAppender with append=true.
        append=true causes logs from every run to pile into one file indefinitely.
        With this setup each day gets its own archive, and test.log is always the current run.
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>target/logs/test.log</file>
        <append>false</append> <!-- false = fresh file each run -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Archive pattern: one file per day -->
            <fileNamePattern>target/logs/test-%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- Keep 7 days of history -->
            <maxHistory>7</maxHistory>
            <!-- Cap total log storage at 100MB -->
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Reduce Selenium/WDM noise — only show warnings from these packages -->
    <logger name="org.openqa.selenium" level="WARN"/>
    <logger name="io.github.bonigarcia" level="WARN"/>
    <logger name="io.cucumber" level="INFO"/>

    <!-- Project classes at DEBUG level for full traceability -->
    <logger name="com.kelompok1" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
