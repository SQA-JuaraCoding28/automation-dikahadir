# =============================================================================
# .env.example — Environment variable template
#
# Copy this file to .env for local overrides (it is git-ignored).
# In CI (GitHub Actions, Jenkins), set these as pipeline secrets/env vars.
#
# These override config.properties values at runtime.
# Variable names are the property key uppercased with dots replaced by underscores.
# =============================================================================

# Target environment
BASE_URL=https://magang.dikahadir.com/

# Browser config
BROWSER=chrome
HEADLESS=true

# Test credentials — inject from CI secrets, never commit real values
# USER_VALID_PASSWORD=your_test_password_here
